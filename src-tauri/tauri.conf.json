{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chart-creator",
  "version": "0.1.0",
  "identifier": "com.chartcreator.music",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node build.js && npx -y http-server dist -p 1420",
    "beforeBuildCommand": "node build.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Chart Creator",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
